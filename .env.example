# 复制这个文件为 .env 并填入真实值
# cp .env.example .env

# SQLite 本地数据库位置
DATABASE_URL="file:./dev.db"

# OpenAI API Key（Phase 2 RAG 问答时需要）
# 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=""

# 对话模型选择：
#   gpt-5-nano      - 最便宜的 reasoning 模型，适合日常问答（推荐）
#   gpt-5-mini      - 能力更强，贵一点
#   gpt-4o-mini     - 经典模型，支持流式和 temperature 调节
#   gpt-4o          - 能力最强的经典模型
OPENAI_CHAT_MODEL="gpt-5-nano"

# 嵌入模型 —— 所有模型共用
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
