// 刘丽航专属留学 App - 数据库 schema
// Phase 1：知识库
// Phase 2：embedding + 聊天
// Phase 2.5：todo + 娱乐小工具（零食/餐厅/菜品）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// 知识库
// ═══════════════════════════════════════════

model KnowledgeEntry {
  id                 String    @id @default(cuid())
  title              String
  contentMd          String
  category           String?
  visibility         String    @default("PRIVATE")
  sourceUrl          String?
  tags               Tag[]     @relation("EntryTags")
  embedding          String?
  embeddingModel     String?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  citations ChatMessageCitation[]

  @@index([category])
  @@index([updatedAt])
}

model Tag {
  id      String           @id @default(cuid())
  name    String           @unique
  color   String?
  entries KnowledgeEntry[] @relation("EntryTags")

  @@index([name])
}

// ═══════════════════════════════════════════
// 聊天
// ═══════════════════════════════════════════

model ChatSession {
  id        String        @id @default(cuid())
  title     String        @default("新对话")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([updatedAt])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String
  content    String
  tokensUsed Int?
  createdAt  DateTime    @default(now())

  citations ChatMessageCitation[]

  @@index([sessionId])
}

model ChatMessageCitation {
  id        String @id @default(cuid())
  messageId String
  entryId   String
  rank      Int
  score     Float

  message ChatMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  entry   KnowledgeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([messageId, entryId])
  @@index([messageId])
}

// ═══════════════════════════════════════════
// Todo 个人待办
// ═══════════════════════════════════════════

model Todo {
  id        String    @id @default(cuid())
  content   String
  done      Boolean   @default(false)
  priority  String    @default("NORMAL") // LOW | NORMAL | HIGH
  note      String?
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([done])
  @@index([priority])
}

// ═══════════════════════════════════════════
// 零食排行榜
// ═══════════════════════════════════════════

model SnackRanking {
  id          String   @id @default(cuid())
  category    String // "AU" 澳洲 | "ZH" 华人
  rank        Int
  name        String
  nameEn      String?
  emoji       String?
  description String?
  priceRange  String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([category, rank])
  @@index([category])
}

// ═══════════════════════════════════════════
// 悉尼餐厅
// ═══════════════════════════════════════════

model Restaurant {
  id         String   @id @default(cuid())
  name       String
  cuisine    String // 粤菜 / 川菜 / 日料 / ...
  suburb     String // CBD / Chatswood / Burwood / ...
  priceLevel Int      @default(2) // 1=$, 2=$$, 3=$$$, 4=$$$$
  note       String?
  emoji      String?
  createdAt  DateTime @default(now())

  @@index([cuisine])
}

// ═══════════════════════════════════════════
// 家常菜
// ═══════════════════════════════════════════

model Dish {
  id         String   @id @default(cuid())
  name       String
  nameEn     String?
  type       String // MEAT 荤 | VEGGIE 素
  difficulty String   @default("EASY") // EASY | MEDIUM | HARD
  note       String?
  emoji      String?
  createdAt  DateTime @default(now())

  @@index([type])
}
