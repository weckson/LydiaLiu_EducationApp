// 刘丽航专属留学 App - 数据库 schema
// Phase 1：知识库
// Phase 2：embedding + 聊天
// Phase 2.5：todo + 娱乐小工具（零食/餐厅/菜品）
// Phase 3：移民方案智能评估器（Assessment + PolicyCache）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// 知识库
// ═══════════════════════════════════════════

model KnowledgeEntry {
  id                 String    @id @default(cuid())
  title              String
  contentMd          String
  category           String?
  visibility         String    @default("PRIVATE")
  sourceUrl          String?
  tags               Tag[]     @relation("EntryTags")
  embedding          String?
  embeddingModel     String?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  citations ChatMessageCitation[]

  @@index([category])
  @@index([updatedAt])
}

model Tag {
  id      String           @id @default(cuid())
  name    String           @unique
  color   String?
  entries KnowledgeEntry[] @relation("EntryTags")

  @@index([name])
}

// ═══════════════════════════════════════════
// 聊天
// ═══════════════════════════════════════════

model ChatSession {
  id        String        @id @default(cuid())
  title     String        @default("新对话")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([updatedAt])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String
  content    String
  tokensUsed Int?
  createdAt  DateTime    @default(now())

  citations ChatMessageCitation[]

  @@index([sessionId])
}

model ChatMessageCitation {
  id        String @id @default(cuid())
  messageId String
  entryId   String
  rank      Int
  score     Float

  message ChatMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  entry   KnowledgeEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([messageId, entryId])
  @@index([messageId])
}

// ═══════════════════════════════════════════
// Todo 个人待办
// ═══════════════════════════════════════════

model Todo {
  id        String    @id @default(cuid())
  content   String
  done      Boolean   @default(false)
  priority  String    @default("NORMAL") // LOW | NORMAL | HIGH
  note      String?
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([done])
  @@index([priority])
}

// ═══════════════════════════════════════════
// 零食排行榜
// ═══════════════════════════════════════════

model SnackRanking {
  id          String   @id @default(cuid())
  category    String // "AU" 澳洲 | "ZH" 华人
  rank        Int
  name        String
  nameEn      String?
  emoji       String?
  description String?
  priceRange  String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([category, rank])
  @@index([category])
}

// ═══════════════════════════════════════════
// 悉尼餐厅
// ═══════════════════════════════════════════

model Restaurant {
  id         String   @id @default(cuid())
  name       String
  cuisine    String // 粤菜 / 川菜 / 日料 / ...
  suburb     String // CBD / Chatswood / Burwood / ...
  priceLevel Int      @default(2) // 1=$, 2=$$, 3=$$$, 4=$$$$
  note       String?
  emoji      String?
  createdAt  DateTime @default(now())

  @@index([cuisine])
}

// ═══════════════════════════════════════════
// 家常菜
// ═══════════════════════════════════════════

model Dish {
  id         String   @id @default(cuid())
  name       String
  nameEn     String?
  type       String // MEAT 荤 | VEGGIE 素
  difficulty String   @default("EASY") // EASY | MEDIUM | HARD
  note       String?
  emoji      String?
  createdAt  DateTime @default(now())

  @@index([type])
}

// ═══════════════════════════════════════════
// 移民方案智能评估器
// ═══════════════════════════════════════════

/// 移民评估 —— 顾问为客户做的完整背景评估 + Plan A/B/C
model Assessment {
  id String @id @default(cuid())

  // —— 客户基础（CRM 升级预留） ——
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  age             Int
  nationality     String?
  maritalStatus   String // SINGLE | MARRIED | DE_FACTO
  partnerEligible Boolean @default(false) // 旧字段保留兼容
  partnerSkillLevel String? // SKILLED_ENGLISH | ENGLISH_ONLY | AU_CITIZEN_PR | NONE

  // —— 学历 ——
  highestDegree   String // DIPLOMA | BACHELOR | MASTER | PHD
  fieldOfStudy    String
  degreeCountry   String // "AU" 或其他国家代码
  graduationYear  Int
  gpa             Float?
  australianStudy Boolean @default(false) // 是否有澳洲 2+ 年学习
  regionalStudy   Boolean @default(false) // 是否在偏远地区学习

  // —— 工作经验（JSON 数组） ——
  workExperience String // JSON: [{jobTitle, company, country, startDate, endDate, hoursPerWeek}]

  // —— 英语 ——
  englishTest      String? // IELTS | PTE | TOEFL | OET
  englishOverall   Float?
  englishListening Float?
  englishReading   Float?
  englishWriting   Float?
  englishSpeaking  Float?
  englishTestDate  DateTime?

  // —— 加分项 ——
  hasNAATI            Boolean @default(false)
  hasProfessionalYear Boolean @default(false)

  // —— 偏好 ——
  targetState     String? // ANY | NSW | VIC | QLD | SA | WA | TAS | NT | ACT
  willingRegional Boolean @default(true)
  budgetTier      String? // LOW | MEDIUM | HIGH
  urgency         String? // LOW | NORMAL | HIGH

  // —— 计算结果（缓存） ——
  calculatedPoints189    Int? // 189 总分
  calculatedPoints190    Int? // 190 总分 = 189 + 5
  calculatedPoints491    Int? // 491 总分 = 189 + 15
  pointsBreakdown        String? // JSON: 分项明细
  recommendedOccupations String? // JSON: [{code, name, assessmentBody, confidence, reason}]
  pathA                  String? // JSON: PathPlan
  pathB                  String? // JSON: PathPlan
  pathC                  String? // JSON: PathPlan
  stateComparison        String? // JSON: [{state, status, points, timeline}]
  recentPolicyUpdates    String? // JSON: 最近 30 天变化摘要
  citedKnowledgeIds      String? // JSON: [knowledgeEntryId] 引用的 SOP
  tokensUsed             Int? // 本次评估消耗的 token 数

  // —— 元信息 ——
  consultantNotes String? // Lydia 手写备注（可编辑）
  dataFreshness   DateTime? // 政策数据抓取时间
  status          String    @default("DRAFT") // DRAFT | PROCESSING | DONE | FAILED
  errorMessage    String? // 生成失败时的错误信息
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([createdAt])
  @@index([clientName])
  @@index([status])
}

/// 政策缓存 —— 避免重复调用 OpenAI web search
model PolicyCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique // 规范化查询字符串的 hash
  query     String // 原始查询字符串（可读）
  content   String // 抓取的内容
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([cacheKey])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════
// 签证文件清单
// ═══════════════════════════════════════════

/// 签证材料清单模板（种子数据，每种签证一套）
model ChecklistTemplate {
  id       String   @id @default(cuid())
  visaType String   @unique // "500" | "189" | "190" | "491" | "482" | "186" | "820" | "143" | "600" | "485"
  visaName String
  items    String // JSON: [{category, name, nameEn, required, note}]
  updatedAt DateTime @updatedAt
}

/// 客户具体清单（从模板生成，可打勾跟踪）
model ClientChecklist {
  id           String   @id @default(cuid())
  clientName   String?
  visaType     String
  visaName     String
  items        String // JSON: [{name, nameEn, category, required, checked, note}]
  assessmentId String? // 可关联到评估
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}

// ═══════════════════════════════════════════
// 社交媒体内容
// ═══════════════════════════════════════════

model ContentPost {
  id               String   @id @default(cuid())
  platform         String // XIAOHONGSHU | WECHAT | INSTAGRAM | DOUYIN | ZHIHU
  topic            String
  title            String
  content          String
  hashtags         String? // JSON: string[]
  emotion          String? // 情绪/意图：ANXIETY | INSPIRE | INFO | ...
  audience         String? // 目标受众：PROSPECTIVE_STUDENT | PARENTS | ...
  titleVariants    String? // JSON: 3 个备选标题
  referenceSources String? // JSON: web search 引用来源
  sourceEntryId    String? // 关联知识条目
  tokensUsed       Int?
  createdAt        DateTime @default(now())

  @@index([platform])
  @@index([emotion])
  @@index([createdAt])
}

// ═══════════════════════════════════════════
// 职业评估匹配工具（独立工具，不需要英语/年龄等 EOI 数据）
// ═══════════════════════════════════════════

model CareerMatch {
  id String @id @default(cuid())

  // —— 客户基础（可选，用于档案）——
  clientName String?

  // —— 学历 ——
  highestDegree   String // DIPLOMA | BACHELOR | MASTER | PHD
  fieldOfStudy   String  // 详细专业名
  degreeCountry  String? // CN / AU / 其他
  graduationYear Int?

  // —— 工作和实习经验（JSON 数组）——
  workExperience String   // JSON: [{jobTitle, company, country, durationYears, description, isInternship}]

  // —— 其他相关信息 ——
  certifications      String? // 持有的证书（如 CFA、PMP、护士执照等）
  australianStudy     Boolean @default(false)
  notes               String? // 自由文本，客户的其他补充

  // —— 计算结果 ——
  status            String  @default("PROCESSING") // PROCESSING | DONE | FAILED | UNMATCHED
  matchedOccupations String? // JSON: 匹配到的职业列表（详细）
  unmatchedReason   String? // 如果一个都匹配不上的原因
  summary           String? // 整体总结
  tokensUsed        Int?
  errorMessage      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}
